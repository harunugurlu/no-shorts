{
	"manifest_version": 3,
	"name": "No Distractions YouTube",
	"description": "Remove distractions from YouTube",
	"version": "2.0",
	"action": {
		"default_popup": "popup.html",
		"default_icon": "no-distractions-youtube-16x16.png"
	},
	"content_scripts": [
		{
			"matches": ["*://www.youtube.com/*"],
			"js": ["removeShorts.js", "focusMode.js"]
		}
	],
	"background": {
		"service_worker": "background.js"
	},
	"permissions": [
		"tabs",
		"storage",
		"webNavigation",
		"notifications"
	],
	"web_accessible_resources": [{
		"resources": ["quotes.txt"],
		"matches": ["chrome-extension://*/*"]
	}]
}